# Ignore generated proxy service directories
polysquid-services/*
!polysquid-services/example/

# Ignore self-service request JSON files (dynamic, not tracked)
self-service/requests/

# Python cache
__pycache__/
*.pyc
*.pyo

# Logs and cache (if any local copies)
*.log
cache/

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.swp